{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2020",
    "lib": ["ES2017", "dom"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist/esm",
    "moduleResolution": "node",
    "strict": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
